# Supabase (forms APIs + browser auth need URL + anon key; service role is server-only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only — never expose in client bundles. Must be the service_role key (long JWT), NOT the anon key.
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket for job application resumes (create in Dashboard → Storage)
SUPABASE_RESUME_BUCKET=resumes

# Resend — team notifications for project inquiries & job applications (https://resend.com)
# If unset, forms still save to Supabase; emails are skipped (see server logs).
RESEND_API_KEY=
# Verified sender, e.g. AsaaseLabs <notifications@yourdomain.com> (or Resend onboarding sender for tests)
EMAIL_FROM=
# Comma-separated inbox(es) that receive notifications
NOTIFY_EMAIL=

# Comma-separated staff emails (must match Supabase auth email). Grants /api/staff/* and inbox UI.
STAFF_EMAILS=
